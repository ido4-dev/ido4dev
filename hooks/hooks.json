{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start-mcp.sh\"",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start-bundle.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start-banner.js\" || true",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-end-state.js\" || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^mcp__plugin_ido4dev_ido4__(refine|ready|start|review|approve|complete|block|unblock|return)_task$",
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"${CLAUDE_PLUGIN_ROOT}/hooks/lib/rule-runner.js\" --rules \"${CLAUDE_PLUGIN_ROOT}/hooks/rules/pre-transition.rules.yaml\" || true",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "^mcp__plugin_ido4dev_ido4__assign_task_to_(wave|sprint|cycle)$",
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"${CLAUDE_PLUGIN_ROOT}/hooks/lib/rule-runner.js\" --rules \"${CLAUDE_PLUGIN_ROOT}/hooks/rules/pre-assign-task.rules.yaml\" || true",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__plugin_ido4dev_ido4__validate_transition",
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"${CLAUDE_PLUGIN_ROOT}/hooks/lib/rule-runner.js\" --rules \"${CLAUDE_PLUGIN_ROOT}/hooks/rules/validate-transition.rules.yaml\" || true",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "^mcp__plugin_ido4dev_ido4__assign_task_to_(wave|sprint|cycle)$",
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"${CLAUDE_PLUGIN_ROOT}/hooks/lib/rule-runner.js\" --rules \"${CLAUDE_PLUGIN_ROOT}/hooks/rules/assign-task.rules.yaml\" || true",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__plugin_ido4dev_ido4__compute_compliance_score",
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"${CLAUDE_PLUGIN_ROOT}/hooks/lib/rule-runner.js\" --rules \"${CLAUDE_PLUGIN_ROOT}/hooks/rules/compliance-score.rules.yaml\" || true",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__plugin_ido4dev_ido4__complete_and_handoff",
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"${CLAUDE_PLUGIN_ROOT}/hooks/lib/rule-runner.js\" --rules \"${CLAUDE_PLUGIN_ROOT}/hooks/rules/complete-and-handoff.rules.yaml\" || true",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "^mcp__plugin_ido4dev_ido4__(refine|ready|start|review|approve|complete|block|unblock|return|shape|bet|ship|kill|plan)_task$",
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"${CLAUDE_PLUGIN_ROOT}/hooks/lib/rule-runner.js\" --rules \"${CLAUDE_PLUGIN_ROOT}/hooks/rules/ai-work-audit.rules.yaml\" || true",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
