{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start-mcp.sh\"",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start-bundle.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start-banner.js\" || true",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-end-state.js\" || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__plugin_ido4dev_ido4__validate_transition",
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"${CLAUDE_PLUGIN_ROOT}/hooks/lib/rule-runner.js\" --rules \"${CLAUDE_PLUGIN_ROOT}/hooks/rules/validate-transition.rules.yaml\" || true",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__plugin_ido4dev_ido4__assign_task_to_(wave|sprint|cycle)",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "A task was just assigned to a container. Based on the tool result, check:\n\n1. Does the result indicate any integrity concerns? (tasks from same capability in different containers)\n2. Does the result indicate any dependency issues? (task depends on work in a later container)\n\nRespond with JSON: {\"decision\": \"block\", \"reason\": \"[concern]\"} ONLY if there's a governance risk. Otherwise {\"decision\": \"allow\"}.\n\nOnly flag real concerns visible in the tool result, not hypothetical ones."
          }
        ]
      }
    ]
  }
}
